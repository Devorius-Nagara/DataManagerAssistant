{
  "manifest_version": 3,
  "name": "Data Manager Assistant",
  "version": "9.6.26",
  "description": "Collects stats from two sites, merges, and prepares TSV for Google Sheets.",
  "key": "",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Data Manager Assistant"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "unlimitedStorage", "activeTab", "scripting", "webRequest", "identity"],
  "oauth2": {
    "client_id": "561573337486-8lnb2e3nm1c7m3eko4drulebcd2ollut.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/spreadsheets"]
  },
  "host_permissions": ["https://*.trackensure.com/*", "https://*.orchard22.com/*", "<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
